# Copy this file to `.env` in the same folder and fill in your key.
#
# Provider selection:
# - If OPENAI_API_KEY is set, backend uses OpenAI.
# - Otherwise it falls back to Groq (GROQ_API_KEY).

# OpenAI (preferred when provided)
OPENAI_API_KEY="sk-your-openai-api-key-here"
# Optional OpenAI overrides
# OPENAI_MODEL="gpt-4o-mini"
# OPENAI_VISION_MODEL="gpt-4o-mini"
# OPENAI_BASE_URL="https://api.openai.com/v1"

# Groq fallback (used only when OPENAI_API_KEY is missing)
# GROQ_API_KEY="gsk-your-groq-api-key-here"
# GROQ_MODEL="llama-3.3-70b-versatile"
# GROQ_VISION_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"

# --- Auth / password reset (backend `backend/.env` or Render env) ---
# JWT_SECRET="long-random-string"
# FRONTEND_URL="https://your-app.vercel.app"
# Password reset emails (pick one):
# RESEND_API_KEY="re_..."
# RESEND_FROM="VibeCoder <onboarding@resend.dev>"
# Or SMTP:
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="..."
# SMTP_PASSWORD="..."
# SMTP_FROM="you@example.com"
