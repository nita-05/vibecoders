# Backend API URL (no trailing slash). Browser calls use this origin.
# Local:
NEXT_PUBLIC_API_BASE="http://localhost:8000"
# Production deploy: set to your API, e.g. https://api.yourdomain.com
# Vercel/Netlify: add this in the project Environment Variables UI so the deploy keeps working.

# Password reset links are built on the backend. On Render, set:
# FRONTEND_URL=https://your-frontend.vercel.app
# and configure RESEND_API_KEY or SMTP_* so "Forgot password" can email the reset link.
